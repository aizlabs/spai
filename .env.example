# API Keys
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...

# Environment
ENVIRONMENT=local

# Optional overrides
ARTICLES_PER_RUN=1

# Alert email (recipient). When set with ALERTS_ENABLED and SMTP credentials, enables SMTP alerts (local or CI).
ALERT_EMAIL=alerts@example.com
# ALERTS_ENABLED=true
# ALERT_SMTP_HOST=smtp.gmail.com
# ALERT_SMTP_PORT=587
# ALERT_SMTP_USERNAME=your@gmail.com
# ALERT_SMTP_PASSWORD=your-app-password
# ALERT_SENDER=AutoSpanishBot <noreply@example.com>

# Telegram alerts are configured in config/*.yaml under alerts.telegram
# telegram:
#   enabled: true
#   bot_token: 123456:telegram-bot-token
#   chat_id: -1001234567890
