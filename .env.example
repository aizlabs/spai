# API Keys
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...

# Environment
ENVIRONMENT=local

# Optional overrides
ARTICLES_PER_RUN=1

# Alert email (recipient). When set with ALERTS_ENABLED and SMTP credentials, enables SMTP alerts (local or CI).
ALERT_EMAIL=alerts@example.com
# ALERTS_ENABLED=true
# ALERT_SMTP_HOST=smtp.gmail.com
# ALERT_SMTP_PORT=587
# ALERT_SMTP_USERNAME=your@gmail.com
# ALERT_SMTP_PASSWORD=your-app-password
# ALERT_SENDER=AutoSpanishBot <noreply@example.com>

# Telegram alerts can be configured in config/*.yaml under alerts.telegram
# or via CI secrets / env vars. If both vars below are set, Telegram alerts
# auto-enable and alert delivery is enabled unless ALERTS_ENABLED=false.
# ALERT_TELEGRAM_BOT_TOKEN=123456:telegram-bot-token
# ALERT_TELEGRAM_CHAT_ID=-1001234567890

# Telegram article publishing uses separate secrets/config from alerts, even if
# you reuse the same bot token. The bot must be an admin in the target channel.
# TELEGRAM_PUBLISH_BOT_TOKEN=123456:telegram-channel-bot-token
# TELEGRAM_PUBLISH_CHAT_ID=-1001234567890
